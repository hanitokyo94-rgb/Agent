modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["sh", "-c", "cd artifacts/api-server && PORT=5000 NODE_ENV=production node --enable-source-maps ./dist/index.mjs"]
build = ["sh", "-c", "pnpm --filter @workspace/app run build && pnpm --filter @workspace/api-server run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-dev.sh"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 23863
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
AI_MODEL = "openai/gpt-5.4-nano"
AI_BASE_URL = "https://ktai.koyeb.app/v1"
